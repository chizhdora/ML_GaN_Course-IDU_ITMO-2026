        "\n",
        "# 7: СВОЯ РЕАЛИЗАЦИЯ (SGD + Elastic Net)\n",
        "\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "\n",
        "class LinearRegressionSGD:\n",
        "    \"\"\"Линейная регрессия с Mini-Batch SGD и Elastic Net регуляризацией\"\"\"\n",
        "\n",
        "    def __init__(self, learning_rate=0.01, lambda_l1=0.001, lambda_l2=0.001,\n",
        "                 n_iter=500, batch_size=64, tol=1e-4, random_state=42):\n",
        "        self.learning_rate = learning_rate\n",
        "        self.lambda_l1 = lambda_l1\n",
        "        self.lambda_l2 = lambda_l2\n",
        "        self.n_iter = n_iter\n",
        "        self.batch_size = batch_size\n",
        "        self.tol = tol\n",
        "        self.random_state = random_state\n",
        "        self.w = None\n",
        "        self.b = None\n",
        "        self.loss_history = []\n",
        "\n",
        "    def fit(self, X, y):\n",
        "        # Преобразование в numpy\n",
        "        X = np.array(X)\n",
        "        y = np.array(y).flatten()\n",
        "\n",
        "        # Стандартизация признаков\n",
        "        self.scaler_X = StandardScaler()\n",
        "        X_scaled = self.scaler_X.fit_transform(X)\n",
        "\n",
        "        # Стандартизация целевой переменной\n",
        "        self.scaler_y = StandardScaler()\n",
        "        y_scaled = self.scaler_y.fit_transform(y.reshape(-1, 1)).flatten()\n",
        "\n",
        "        # Инициализация параметров\n",
        "        n_objects, n_features = X_scaled.shape\n",
        "        self.w = np.zeros(n_features)\n",
        "        self.b = 0.0\n",
        "\n",
        "        # Генератор случайных чисел\n",
        "        rng = np.random.RandomState(self.random_state)\n",
        "\n",
        "        # История потерь\n",
        "        self.loss_history = []\n",
        "        prev_loss = np.inf\n",
        "\n",
        "        # Цикл обучения\n",
        "        for epoch in range(self.n_iter):\n",
        "            # Перемешивание данных\n",
        "            indices = rng.permutation(n_objects)\n",
        "\n",
        "            # Mini-batch обучение\n",
        "            for start_idx in range(0, n_objects, self.batch_size):\n",
        "                batch_indices = indices[start_idx:start_idx + self.batch_size]\n",
        "                X_batch = X_scaled[batch_indices]\n",
        "                y_batch = y_scaled[batch_indices]\n",
        "                m = len(y_batch)\n",
        "\n",
        "                # Предсказания и ошибки\n",
        "                y_pred_batch = X_batch @ self.w + self.b\n",
        "                errors = y_pred_batch - y_batch\n",
        "\n",
        "                # Градиенты\n",
        "                grad_w = (1/m) * X_batch.T @ errors\n",
        "                grad_b = np.mean(errors)\n",
        "\n",
        "                # Elastic Net регуляризация\n",
        "                grad_w += self.lambda_l2 * self.w + self.lambda_l1 * np.sign(self.w)\n",
        "\n",
        "                # Обновление параметров\n",
        "                self.w -= self.learning_rate * grad_w\n",
        "                self.b -= self.learning_rate * grad_b\n",
        "\n",
        "            # Вычисление полной потери\n",
        "            y_pred_full = X_scaled @ self.w + self.b\n",
        "            mse = np.mean((y_scaled - y_pred_full) ** 2)\n",
        "            reg = 0.5 * self.lambda_l2 * np.sum(self.w ** 2) + self.lambda_l1 * np.sum(np.abs(self.w))\n",
        "            loss = mse + reg\n",
        "            self.loss_history.append(loss)\n",
        "\n",
        "            # Ранняя остановка\n",
        "            if abs(prev_loss - loss) < self.tol:\n",
        "                print(f\"Ранняя остановка на эпохе {epoch+1}\")\n",
        "                break\n",
        "            prev_loss = loss\n",
        "\n",
        "            # Вывод прогресса (каждые 100 эпох)\n",
        "            if (epoch + 1) % 100 == 0:\n",
        "                print(f\"Эпоха {epoch+1}/{self.n_iter}, Loss = {loss:.6f}\")\n",
        "\n",
        "        return self\n",
        "\n",
        "    def predict(self, X):\n",
        "        X = np.array(X)\n",
        "        X_scaled = self.scaler_X.transform(X)\n",
        "        return self.scaler_y.inverse_transform(\n",
        "            (X_scaled @ self.w + self.b).reshape(-1, 1)\n",
        "        ).flatten()\n",
        "\n",
