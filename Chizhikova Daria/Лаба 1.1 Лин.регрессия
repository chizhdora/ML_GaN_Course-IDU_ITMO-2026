      "cell_type": "code",
      "metadata": {
        "id": "q0l76cbaKzYg"
      },
      "source": [
        "### Реализуйте настройку w и b с помощью рассмотренного выше метода наименьших квадратов.\n",
        "def linear_regression_moore_penrose(X, y):\n",
        "\n",
        "    # Метод наименьших квадратов через псевдообратную матрицу (Мура-Пенроуза)\n",
        "    #w = (X^T * X)^(-1) * X^T * y\n",
        "    # Добавляем столбец единиц для bias (x0 = 1)\n",
        "    X_with_bias = np.hstack([np.ones((X.shape[0], 1)), X])\n",
        "\n",
        "    # Аналитическое решение через псевдообратную матрицу\n",
        "    w = np.linalg.pinv(X_with_bias.T @ X_with_bias) @ X_with_bias.T @ y\n",
        "\n",
        "    return w[0], w[1:]  # bias, weights\n",
        "\n",
        "# Обучаем нашу реализацию\n",
        "my_bias, my_weights = linear_regression_moore_penrose(X_train, y_train)\n",
        "\n",
        "# Предсказания нашей модели\n",
        "y_pred_train_my = my_bias + X_train @ my_weights\n",
        "y_pred_test_my = my_bias + X_test @ my_weights\n",
        "\n",
        "# Обучаем sklearn модель\n",
        "sklearn_model = LinearRegression()\n",
        "sklearn_model.fit(X_train, y_train)\n",
        "y_pred_test_sklearn = sklearn_model.predict(X_test)\n"
      ],
      "execution_count": null,
      "outputs": []
