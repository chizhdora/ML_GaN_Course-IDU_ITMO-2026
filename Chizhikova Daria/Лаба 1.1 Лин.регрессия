      },
      "source": [
        "### попробуйте реализовать настройку w и b с помощью рассмотренного выше метода наименьших квадратов.\n",
        "# Функция для аналитического решения МНК\n",
        "def train_linear_regression_mnk(X, y):\n",
        "    \"\"\"\n",
        "    X: массив признаков (n_samples, 1)\n",
        "    y: массив целевых значений (n_samples,)\n",
        "    Возвращает: w (вес), b (bias)\n",
        "    \"\"\"\n",
        "    # Добавляем столбец единиц для учета bias\n",
        "    X_with_bias = np.hstack([np.ones((X.shape[0], 1)), X])\n",
        "\n",
        "    # Аналитическое решение: w = (X^T X)^(-1) X^T y\n",
        "    w = np.linalg.pinv(X_with_bias.T @ X_with_bias) @ X_with_bias.T @ y\n",
        "\n",
        "    # bias — это первый элемент, вес — второй\n",
        "    b = w[0]\n",
        "    w1 = w[1]\n",
        "\n",
        "    return w1, b\n",
        "\n",
        "# Получаем обучающие данные\n",
        "X_train_wave = data['x_train'].reshape(-1, 1)\n",
        "y_train_wave = data['y_train']\n",
        "\n",
        "# Обучаем нашу реализацию МНК\n",
        "w_my, b_my = train_linear_regression_mnk(X_train_wave, y_train_wave)\n",
        "print(f\"\\nРеализация МНК: w = {w_my:.4f}, b = {b_my:.4f}\")\n",
        "\n",
        "# Обучаем sklearn для сравнения\n",
        "sklearn_model = LinearRegression()\n",
        "sklearn_model.fit(X_train_wave, y_train_wave)\n",
        "print(f\"Sklearn LinearRegression: w = {sklearn_model.coef_[0]:.4f}, b = {sklearn_model.intercept_:.4f}\")\n"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
